#!/usr/bin/env bash
# Regenerate SOURCES.md from every .provenance.json sidecar in the repo.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

REPO_ROOT="$REPO_ROOT" python3 - <<'PYEOF'
import json
import os
import sys
from datetime import date

repo_root = os.environ["REPO_ROOT"]

sidecars = []
for root, dirs, files in os.walk(repo_root):
    # Skip .git and other version-control noise
    dirs[:] = [d for d in dirs if d not in (".git", "node_modules")]
    for name in files:
        if name == ".provenance.json" or name.endswith(".provenance.json"):
            sidecars.append(os.path.join(root, name))
sidecars.sort()

# (local_path_str, entry_dict)
entries = []
for s in sidecars:
    rel = os.path.relpath(s, repo_root)
    basename = os.path.basename(s)
    if basename == ".provenance.json":
        # Folder-level sidecar — describes the parent directory
        local = os.path.dirname(rel)
    else:
        # File-level sidecar — describes the file sans .provenance.json suffix
        local = rel[: -len(".provenance.json")]

    try:
        with open(s) as f:
            data = json.load(f)
    except Exception as e:
        print(f"WARN: skipping malformed sidecar {rel}: {e}", file=sys.stderr)
        continue

    prov = data.get("provenance") if isinstance(data, dict) else None
    if not isinstance(prov, list):
        print(f"WARN: skipping {rel}: missing or non-list 'provenance' field", file=sys.stderr)
        continue

    for entry in prov:
        entries.append((local, entry))

today = date.today().isoformat()
lines = [
    "# Sources",
    "",
    "_Auto-generated by `bin/sources-index` — do not edit manually._  ",
    f"_Last generated: {today}_",
    "",
]

if not entries:
    lines += [
        "No external sources recorded yet.",
        "",
        "Run `bin/adopt --help` to start tracking adopted items.",
        "",
    ]
else:
    lines += [
        "## By path",
        "",
        "| Local path | Source | Commit | Path in source | Mode | License | Adopted |",
        "|---|---|---|---|---|---|---|",
    ]
    for local, e in entries:
        commit = e.get("commit", "")
        commit_short = commit[:8] if commit else "?"
        lines.append(
            "| `{lp}` | {src} | `{c}` | `{p}` | {m} | {lic} | {d} |".format(
                lp=local,
                src=e.get("source", "?"),
                c=commit_short,
                p=e.get("path", "?"),
                m=e.get("adopted-as", "?"),
                lic=e.get("license", "?"),
                d=e.get("adopted-at", "?"),
            )
        )
    lines.append("")

    lines += ["## By source", ""]
    by_source = {}
    for local, e in entries:
        by_source.setdefault(e.get("source", "?"), []).append((local, e))
    for src in sorted(by_source.keys()):
        lines.append(f"### {src}")
        lines.append("")
        for local, e in sorted(by_source[src], key=lambda t: t[0]):
            commit = e.get("commit", "")
            commit_short = commit[:8] if commit else "?"
            lines.append(
                f"- `{local}` ({e.get('adopted-as', '?')} @ `{commit_short}`, {e.get('license', '?')})"
            )
        lines.append("")

with open(os.path.join(repo_root, "SOURCES.md"), "w") as f:
    f.write("\n".join(lines))

n_entries = len(entries)
n_files = len(sidecars)
print(
    "Wrote SOURCES.md ({n_e} entr{ey} across {n_f} sidecar file{s}).".format(
        n_e=n_entries,
        ey="y" if n_entries == 1 else "ies",
        n_f=n_files,
        s="" if n_files == 1 else "s",
    )
)
PYEOF
